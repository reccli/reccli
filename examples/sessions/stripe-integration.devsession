  "artifacts": {
    "files": {
      "middleware/rawBody.js": {
        "content": "// Middleware to capture raw body for Stripe webhook signature verification\nmodule.exports = (req, res, next) => {\n  if (req.originalUrl === '/api/webhooks/stripe') {\n    let data = '';\n    req.on('data', chunk => {\n      data += chunk;\n    });\n    req.on('end', () => {\n      req.rawBody = data;\n      next();\n    });\n  } else {\n    next();\n  }\n};",
        "encoding": "utf-8"
      }
    }
  }
