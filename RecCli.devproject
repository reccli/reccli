  "project": {
    "name": "RecCli",
    "description": "RecCli is a temporal memory engine for coding agents. It implements a tri-layer memory system: full conversation history as source of truth, compacted session summaries for active working memory, and an optional project outline for cross-session context, with temporal links enabling exact reasoning recovery instead of lossy compaction.",
    "status": "active",
    "source": "auto"
  },
