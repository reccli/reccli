    {
      "feature_id": "feat_agent_audit_harness",
      "title": "Agent Audit Harness",
      "description": "Read-only feature-scoped multi-agent audits dispatched through subscription-auth CLI adapters (Claude Code or Codex). Builds a feature-scoped context pack from .devproject, fans out N independent audit agents, parses structured findings, aggregates a severity-sorted merged report, persists bundle.json for caller-side recovery on MCP timeout, supports single-agent replay, single-finding patch proposal with git-apply check, and cross-agent finding consolidation (deterministic clustering with optional LLM-judge dedup, bounded by max_judge_clusters with never-throws fallback).",
      "status": "in-progress",
      "file_boundaries": [
