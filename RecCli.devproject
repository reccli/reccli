  "project": {
    "name": "reccli",
    "description": "reccli is a temporal memory engine for AI coding agents implementing a tri-layer memory system: .devproject (project feature map), .devsession summary (compacted working memory), and .devsession full conversation (source of truth). It runs as an MCP server and Claude Code hook integration, enabling agents to accumulate structured memory across sessions through hybrid search, LLM summarization, and temporal-semantic linking between memory layers.",
    "status": "active",
    "source": "auto"
  },
  "features": [
    {
      "feature_id": "feat_devsession_file_format_session_management",
      "feature_version": 1,
      "title": ".devsession File Format & Session Management",
      "description": "Core .devsession file format manager, conversation message tagging, ID-stable reindexing after compaction, and session checkpoint tracking. This is the source-of-truth layer of the tri-layer memory system.",
